### Version B — Logic Apps + Service Bus test scenarios
### These payloads get dropped onto the Service Bus queue that triggers the Logic App.
### You can send them via:
###   - Azure Portal → Service Bus → Queue → Service Bus Explorer → Send messages
###   - An HTTP trigger function that forwards the payload to the queue
###   - Azure CLI: az servicebus queue message send
###
### If you have an HTTP trigger function that enqueues messages, use it here:

@host = http://localhost:7071

###############################################################################
# Validator endpoint smoke test (called directly by Logic App)
###############################################################################
POST {{host}}/api/validate
Content-Type: application/json

{
  "employee_name": "Dharti Patel",
  "employee_email": "dharti@example.com",
  "amount": 45.00,
  "category": "meals",
  "description": "Team lunch",
  "manager_email": "manager@example.com"
}

###############################################################################
# Scenario 1: Valid expense under $100 → auto-approved subscription fires
###############################################################################
# Payload to send to the Service Bus queue:
{
  "employee_name": "Dharti Patel",
  "employee_email": "dharti@example.com",
  "amount": 45.00,
  "category": "meals",
  "description": "Team lunch",
  "manager_email": "manager@example.com"
}

###############################################################################
# Scenario 2: Valid expense >= $100, manager approves
###############################################################################
{
  "employee_name": "Dharti Patel",
  "employee_email": "dharti@example.com",
  "amount": 450.00,
  "category": "equipment",
  "description": "External monitor",
  "manager_email": "manager@example.com"
}

###############################################################################
# Scenario 3: Valid expense >= $100, manager rejects
###############################################################################
{
  "employee_name": "Dharti Patel",
  "employee_email": "dharti@example.com",
  "amount": 1200.00,
  "category": "travel",
  "description": "Conference flight",
  "manager_email": "manager@example.com"
}

###############################################################################
# Scenario 4: No manager response → escalated
###############################################################################
{
  "employee_name": "Dharti Patel",
  "employee_email": "dharti@example.com",
  "amount": 799.00,
  "category": "software",
  "description": "JetBrains license",
  "manager_email": "slow-manager@example.com"
}

###############################################################################
# Scenario 5: Missing required fields
###############################################################################
{
  "employee_name": "Dharti Patel",
  "amount": 50.00,
  "category": "meals"
}

###############################################################################
# Scenario 6: Invalid category
###############################################################################
{
  "employee_name": "Dharti Patel",
  "employee_email": "dharti@example.com",
  "amount": 75.00,
  "category": "entertainment",
  "description": "Team movie night",
  "manager_email": "manager@example.com"
}
